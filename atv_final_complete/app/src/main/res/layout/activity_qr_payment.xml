<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080B10">

    <LinearLayout
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="36dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A-TV"
            android:textColor="#00C2FF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buy Access Key"
            android:textColor="#5A6A7A"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- QR Card -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="20dp">
            <ImageView
                android:id="@+id/qrImage"
                android:layout_width="260dp"
                android:layout_height="260dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/qrError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF4D4D"
            android:textSize="13sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 Scan QR to continue setup process"
            android:textColor="#E8EDF2"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use your phone camera to scan this code and complete payment"
            android:textColor="#5A6A7A"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="28dp"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/btn_register_bg"
            android:text="BACK TO LOGIN"
            android:textColor="#00C2FF"
            android:textSize="13sp"/>

    </LinearLayout>
</RelativeLayout>
