<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Player - ExoPlayer default controls OFF -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        app:use_controller="false"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <!-- Channel Name OSD -->
    <TextView
        android:id="@+id/channelName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="20dp"
        android:layout_marginTop="80dp"
        android:background="@drawable/osd_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <!-- Loading -->
    <LinearLayout
        android:id="@+id/loadingLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="#00C2FF"/>
        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Loading channels..."
            android:textColor="#AAFFFFFF"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- OVERLAY (single touch shows/hides this) -->
    <LinearLayout
        android:id="@+id/overlayPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bar_bg_top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- Channels -->
            <LinearLayout
                android:id="@+id/btnMenu"
                android:layout_width="64dp"
                android:layout_height="52dp"
                android:background="@drawable/ctrl_btn_bg"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="☰" android:textColor="#00C2FF" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="List" android:textColor="#AAFFFFFF" android:textSize="9sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A-TV"
                android:textColor="#00C2FF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"/>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <!-- Ratio -->
            <LinearLayout
                android:id="@+id/btnRatio"
                android:layout_width="64dp"
                android:layout_height="52dp"
                android:background="@drawable/ctrl_btn_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⬜" android:textColor="#00C2FF" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Ratio" android:textColor="#AAFFFFFF" android:textSize="9sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/btnProfile"
                android:layout_width="64dp"
                android:layout_height="52dp"
                android:background="@drawable/ctrl_btn_bg"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👤" android:textColor="#00C2FF" android:textSize="20sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Profile" android:textColor="#AAFFFFFF" android:textSize="9sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- SPACER (middle clickable area) -->
        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- BOTTOM BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bar_bg_bottom"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- Prev -->
            <LinearLayout
                android:id="@+id/btnPrev"
                android:layout_width="72dp"
                android:layout_height="52dp"
                android:background="@drawable/ctrl_btn_bg"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⏮" android:textColor="#00C2FF" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Prev" android:textColor="#AAFFFFFF" android:textSize="9sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Play/Pause -->
            <LinearLayout
                android:id="@+id/btnPlayPause"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:background="@drawable/playpause_btn_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:id="@+id/playPauseIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏸" android:textColor="#000000" android:textSize="22sp"/>
                <TextView
                    android:id="@+id/playPauseLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pause" android:textColor="#44000000" android:textSize="9sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Next -->
            <LinearLayout
                android:id="@+id/btnNext"
                android:layout_width="72dp"
                android:layout_height="52dp"
                android:background="@drawable/ctrl_btn_bg"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⏭" android:textColor="#00C2FF" android:textSize="22sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Next" android:textColor="#AAFFFFFF" android:textSize="9sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Channel name bottom ticker (always visible) -->
    <TextView
        android:id="@+id/currentChName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/osd_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:visibility="gone"/>

    <!-- SIDE PANEL -->
    <LinearLayout
        android:id="@+id/sidePanel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@drawable/side_panel_bg"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:visibility="gone">

        <!-- Category Tabs -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:scrollbars="none"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="4dp">
            <LinearLayout
                android:id="@+id/categoryTabs"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>
        </HorizontalScrollView>

        <!-- Search -->
        <EditText
            android:id="@+id/searchInput"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/search_bg"
            android:hint="🔍  Search..."
            android:textColorHint="#5A6A7A"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text"
            android:imeOptions="actionSearch"/>

        <!-- Channel List -->
        <ListView
            android:id="@+id/channelList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="#1E2830"
            android:dividerHeight="1dp"/>

    </LinearLayout>

</FrameLayout>
