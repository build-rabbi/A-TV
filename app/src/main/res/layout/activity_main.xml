<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080B10">

    <!-- Background gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient" />

    <!-- Center card -->
    <LinearLayout
        android:layout_width="480dp"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="48dp">

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="A-TV"
            android:textColor="#00C2FF"
            android:textSize="52sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Premium IPTV Player"
            android:textColor="#5A6A7A"
            android:textSize="14sp"
            android:letterSpacing="0.05"
            android:layout_marginBottom="48dp" />

        <!-- Key label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCESS KEY"
            android:textColor="#5A6A7A"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <!-- Key input -->
        <EditText
            android:id="@+id/etKey"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/input_bg"
            android:hint="Enter your access key"
            android:textColorHint="#3A4A5A"
            android:inputType="textVisiblePassword"
            android:imeOptions="actionDone"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textColor="#E8EDF2"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:focusable="true"
            android:nextFocusDown="@id/btnEnter"
            android:layout_marginBottom="16dp" />

        <!-- Enter button -->
        <Button
            android:id="@+id/btnEnter"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/btn_enter_bg"
            android:focusable="true"
            android:nextFocusUp="@id/etKey"
            android:nextFocusDown="@id/btnRegister"
            android:text="ENTER"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp" />

        <!-- Register button -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/btn_register_bg"
            android:focusable="true"
            android:nextFocusUp="@id/btnEnter"
            android:text="BUY / REGISTER KEY"
            android:textColor="#00C2FF"
            android:textSize="14sp"
            android:letterSpacing="0.06" />

    </LinearLayout>

    <!-- Bottom info -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:text="© A-TV Premium — All rights reserved"
        android:textColor="#2A3A4A"
        android:textSize="11sp" />

</RelativeLayout>
