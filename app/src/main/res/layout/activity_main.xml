<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A-TV Player"
        android:textColor="#FFFFFF"
        android:textSize="42sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your access key to continue"
        android:textColor="#777777"
        android:textSize="16sp"
        android:layout_marginBottom="52dp" />

    <EditText
        android:id="@+id/etKey"
        android:layout_width="420dp"
        android:layout_height="56dp"
        android:background="@drawable/edittext_bg"
        android:hint="Access Key"
        android:hintTextColor="#555555"
        android:inputType="text"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:focusable="true"
        android:nextFocusDown="@id/btnEnter"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnEnter"
        android:layout_width="420dp"
        android:layout_height="56dp"
        android:background="@drawable/btn_primary_bg"
        android:focusable="true"
        android:nextFocusUp="@id/etKey"
        android:nextFocusDown="@id/btnRegister"
        android:text="ENTER"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:letterSpacing="0.1"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnRegister"
        android:layout_width="420dp"
        android:layout_height="56dp"
        android:background="@drawable/btn_secondary_bg"
        android:focusable="true"
        android:nextFocusUp="@id/btnEnter"
        android:text="REGISTER / BUY KEY"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:letterSpacing="0.05" />

</LinearLayout>
