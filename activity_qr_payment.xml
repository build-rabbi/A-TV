<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080B10">

    <!-- Background gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient"/>

    <!-- Centered horizontal layout for TV landscape -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="60dp"
        android:paddingEnd="60dp">

        <!-- Left: QR Code -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- QR White background box -->
            <LinearLayout
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:background="#FFFFFF"
                android:padding="14dp"
                android:gravity="center">
                <ImageView
                    android:id="@+id/qrImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:adjustViewBounds="false"/>
            </LinearLayout>

            <TextView
                android:id="@+id/qrError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF4D4D"
                android:textSize="12sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="260dp"
            android:background="#1E2830"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"/>

        <!-- Right: Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="start">

            <!-- App logo text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A-TV"
                android:textColor="#00C2FF"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium IPTV Player"
                android:textColor="#5A6A7A"
                android:textSize="13sp"
                android:layout_marginBottom="28dp"/>

            <!-- Step 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <TextView android:layout_width="26dp" android:layout_height="26dp"
                    android:background="@drawable/osd_bg" android:text="1"
                    android:textColor="#00C2FF" android:textSize="12sp" android:textStyle="bold"
                    android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Point your phone camera at the QR code"
                    android:textColor="#E8EDF2" android:textSize="13sp"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>

            <!-- Step 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <TextView android:layout_width="26dp" android:layout_height="26dp"
                    android:background="@drawable/osd_bg" android:text="2"
                    android:textColor="#00C2FF" android:textSize="12sp" android:textStyle="bold"
                    android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Complete payment on your phone"
                    android:textColor="#E8EDF2" android:textSize="13sp"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>

            <!-- Step 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="32dp">
                <TextView android:layout_width="26dp" android:layout_height="26dp"
                    android:background="@drawable/osd_bg" android:text="3"
                    android:textColor="#00C2FF" android:textSize="12sp" android:textStyle="bold"
                    android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Enter the key you receive on this screen"
                    android:textColor="#E8EDF2" android:textSize="13sp"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>

            <!-- Payment URL label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAYMENT PAGE"
                android:textColor="#5A6A7A"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="build-rabbi.github.io/A-TV/bkash-payment.html"
                android:textColor="#00C2FF"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="28dp"/>

            <!-- Back button -->
            <Button
                android:id="@+id/btnBack"
                android:layout_width="220dp"
                android:layout_height="50dp"
                android:background="@drawable/btn_register_bg"
                android:text="BACK TO LOGIN"
                android:textColor="#00C2FF"
                android:textSize="13sp"
                android:letterSpacing="0.08"/>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
