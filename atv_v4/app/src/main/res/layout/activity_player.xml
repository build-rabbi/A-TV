<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Video Player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"/>

    <!-- Channel Name Overlay (top-left, auto-hide) -->
    <TextView
        android:id="@+id/channelName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="20dp"
        android:layout_marginTop="72dp"
        android:background="#BB000000"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <!-- Loading -->
    <LinearLayout
        android:id="@+id/loadingLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#00C2FF"/>
        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Loading channels..."
            android:textColor="#AAFFFFFF"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone">

        <!-- Channel List Button -->
        <LinearLayout
            android:id="@+id/btnMenu"
            android:layout_width="72dp"
            android:layout_height="44dp"
            android:background="@drawable/ctrl_btn_bg"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="☰" android:textColor="#FFFFFF" android:textSize="16sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Channels" android:textColor="#AAFFFFFF" android:textSize="9sp"/>
        </LinearLayout>

        <!-- Spacer -->
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- A-TV title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A-TV"
            android:textColor="#00C2FF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_weight="0"/>

        <!-- Spacer -->
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- Ratio Button -->
        <LinearLayout
            android:id="@+id/btnRatio"
            android:layout_width="72dp"
            android:layout_height="44dp"
            android:background="@drawable/ctrl_btn_bg"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⬜" android:textColor="#FFFFFF" android:textSize="16sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ratio" android:textColor="#AAFFFFFF" android:textSize="9sp"/>
        </LinearLayout>

        <!-- Profile Button -->
        <LinearLayout
            android:id="@+id/btnProfile"
            android:layout_width="72dp"
            android:layout_height="44dp"
            android:background="@drawable/ctrl_btn_bg"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textColor="#FFFFFF" android:textSize="16sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profile" android:textColor="#AAFFFFFF" android:textSize="9sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone">

        <!-- Prev Button -->
        <LinearLayout
            android:id="@+id/btnPrev"
            android:layout_width="80dp"
            android:layout_height="44dp"
            android:background="@drawable/ctrl_btn_bg"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginEnd="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="◀  Prev" android:textColor="#FFFFFF" android:textSize="13sp"/>
        </LinearLayout>

        <!-- Channel name center -->
        <TextView
            android:id="@+id/currentChName"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:singleLine="true"/>

        <!-- Next Button -->
        <LinearLayout
            android:id="@+id/btnNext"
            android:layout_width="80dp"
            android:layout_height="44dp"
            android:background="@drawable/ctrl_btn_bg"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginStart="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Next  ▶" android:textColor="#FFFFFF" android:textSize="13sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- SIDE PANEL -->
    <LinearLayout
        android:id="@+id/sidePanel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#F00E1318"
        android:orientation="vertical"
        android:paddingTop="60dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_margin="10dp"
            android:background="@drawable/search_bg"
            android:hint="🔍  Search channels..."
            android:textColorHint="#5A6A7A"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text"
            android:imeOptions="actionSearch"/>

        <ListView
            android:id="@+id/channelList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="#1E2830"
            android:dividerHeight="1dp"/>

    </LinearLayout>

</FrameLayout>
